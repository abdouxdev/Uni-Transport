# ==========================================
# VERCEL FRONTEND CONFIGURATION (.env)
# ==========================================
# Set this in Vercel Dashboard -> Settings -> Environment Variables
# Provide the public URL of your deployed backend API
# Example: https://transport-backend.onrender.com/api
VITE_API_URL=http://localhost:3001/api

# ==========================================
# RENDER BACKEND CONFIGURATION (.env)
# ==========================================
# Set these in Render Dashboard -> Environment Variables
# The connection string for your online MySQL database (e.g., Aiven, PlanetScale, Render)
DATABASE_URL=mysql://user:password@host:port/database

# A secure random string for JWT token generation
JWT_SECRET=your-super-secret-production-key

# Backend API Port (Render uses 10000 by default)
PORT=10000
NODE_ENV=production
